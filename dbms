-- drop database if exists unidb;

create table student
(studentid int not null, first_name varchar(15) not null, last_name varchar(15) not null, dob date, email varchar(50));
 drop table student;

create table course 
(course_id int primary key not null, course_name varchar(10), credit int check(credit>0));
 drop table course;

create table enrollment
(studentid int,course_id int,en_id int primary key, c_id int , grade varchar(30),
foreign key (studentid) references student(studentid)
	on update cascade
    on delete cascade,
foreign key(course_id) references course(course_id)
	on update cascade
    on delete set null
);
-- drop table enrollment;
create table attandance(
studentid int, course_id int, date date,
primary key(studentid, course_id,date)
); 
-- drop table attandance;

create table teachers(
t_id int primary key,
name varchar(50),
dept varchar(50) default "CSE"
);
drop table teachers;


